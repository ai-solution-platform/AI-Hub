#!/bin/sh
# .githooks/pre-commit — I-NEW-2 · K.23 · 29 Apr 2026
# Pre-Edit Lint Gate · Runs DAS sweep + Hub-Index sync-check before commit.
# Owner: HoEng #21 + Senior SDET #31 + #63 FJA-CDCA
#
# Install (one-time per Mac):
#   git config core.hooksPath .githooks
#
# Bypass (when intentional · use sparingly):
#   git commit --no-verify

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "🔍 Pre-commit lint gate (I-NEW-2 · K.23)"

# Detect if any non-exempt file is staged
STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -v -E '^(archive|launches|founder-story|foundational-apr17|scripts|canonical|docs)/' | grep -E '\.(html|md)$' || true)

if [ -z "$STAGED" ]; then
    echo "   No consumer-facing HTML/MD staged — skipping DAS lint."
    exit 0
fi

# 1. DAS canonical lint (P0=block · P1=advisory)
if [ -f scripts/vm-canonical-lint.py ]; then
    echo "   → DAS canonical sweep..."
    DAS_OUT=$(python3 scripts/vm-canonical-lint.py --no-report 2>&1)
    P0_LINE=$(echo "$DAS_OUT" | sed 's/\x1b\[[0-9;]*m//g' | grep -E "^Total: P0=[0-9]+" | head -1)
    P0_COUNT=$(echo "$P0_LINE" | grep -oE "P0=[0-9]+" | grep -oE "[0-9]+" || echo "0")

    if [ "$P0_COUNT" != "0" ] && [ -n "$P0_COUNT" ]; then
        echo ""
        echo "❌ COMMIT BLOCKED: DAS lint found $P0_COUNT P0 violation(s)"
        echo ""
        echo "$DAS_OUT" | sed 's/\x1b\[[0-9;]*m//g' | grep -B1 "P0\]" | head -30
        echo ""
        echo "   Fix options:"
        echo "   1. python3 scripts/das-bulk-fix.py --apply    # auto-remediate"
        echo "   2. Manual edit · update canonical SSOT first"
        echo "   3. git commit --no-verify                     # bypass (use sparingly)"
        exit 1
    fi
    echo "   ✅ DAS lint P0=0"
fi

# 2. Hub-Index sync-check (only if Hub-Index or related files staged)
HUB_STAGED=$(echo "$STAGED" | grep -E '(ANTS-2\.0-Hub-Index|command-center)' || true)
if [ -n "$HUB_STAGED" ] && [ -f scripts/hub-index-sync-check.py ]; then
    echo "   → Hub-Index sync check..."
    if ! python3 scripts/hub-index-sync-check.py 2>&1 | grep -q "ALL CLEAN"; then
        echo ""
        echo "❌ COMMIT BLOCKED: Hub-Index sync check failed"
        python3 scripts/hub-index-sync-check.py 2>&1 | tail -10
        echo ""
        echo "   Run: python3 scripts/hub-index-sync-check.py  for details"
        exit 1
    fi
    echo "   ✅ Hub-Index sync check ALL CLEAN"
fi

# 3. Hub-Index visual regression (only if Hub-Index staged)
HUB_DIRECT=$(echo "$STAGED" | grep -E 'ANTS-2\.0-Hub-Index\.html$' || true)
if [ -n "$HUB_DIRECT" ] && [ -f scripts/hub-index-visual-test.py ]; then
    echo "   → Hub-Index visual regression..."
    if ! python3 scripts/hub-index-visual-test.py --strict 2>&1 | grep -q "ALL CLEAN"; then
        echo ""
        echo "❌ COMMIT BLOCKED: Hub-Index visual regression failed"
        python3 scripts/hub-index-visual-test.py 2>&1 | tail -10
        echo ""
        echo "   If this is intentional structural change:"
        echo "   1. python3 scripts/hub-index-visual-test.py --update-baseline"
        echo "   2. git add canonical/hub-index-baseline.json"
        echo "   3. retry commit"
        exit 1
    fi
    echo "   ✅ Hub-Index visual regression ALL CLEAN"
fi

echo "✅ All pre-commit gates passed"
